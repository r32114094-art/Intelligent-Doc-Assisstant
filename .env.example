# ============================================================================
# 智能文档问答助手 — 环境变量配置模板
# ============================================================================
# 复制此文件为 .env 并填入你的 API 密钥:
#   cp .env.example .env
#
# 系统要求：Python 3.10+
# ============================================================================

# ================================
# LLM 配置 — DeepSeek API
# ================================
# 在 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_TIMEOUT=60

# ================================
# Embedding 配置 — 阿里云 DashScope
# ================================
# 在 https://dashscope.aliyun.com/ 获取 API Key
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v4
EMBED_API_KEY=your_dashscope_api_key_here
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ================================
# 向量数据库 — Qdrant Cloud
# ================================
# 在 https://cloud.qdrant.io/ 创建集群并获取 URL 和 API Key
QDRANT_URL=https://your-cluster-id.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30
